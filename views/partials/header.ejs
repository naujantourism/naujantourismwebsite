<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= typeof title !=='undefined' ? title : 'Naujan Tourism' %>
    </title>
    <link rel="icon" type="image/jpeg" href="<%= typeof imageBaseUrl !== 'undefined' ? imageBaseUrl : '' %>/images/logo/naujanlogo.jpg">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>

<body>
    <a href="#main-content" class="skip-to-content">Skip to main content</a>
    <script>
        (function () {
            var saved = localStorage.getItem('theme');
            var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
            var theme = saved || (prefersDark ? 'dark' : 'light');
            document.documentElement.setAttribute('data-theme', theme);
        })();
        window.__userFavorites = <%- typeof userFavorites !== 'undefined' ? JSON.stringify(userFavorites) : '[]' %>;
        window.__userRatings = <%- typeof userRatings !== 'undefined' ? JSON.stringify(userRatings) : '{}' %>;
        window.__isLoggedIn = <%- (typeof user !== 'undefined' && user) ? 'true' : 'false' %>;
    </script>
    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" href="/">
                <img src="<%= typeof imageBaseUrl !== 'undefined' ? imageBaseUrl : '' %>/images/logo/naujanlogo.jpg" alt="Naujan Tourism Logo" width="36" height="36"
                    class="d-inline-block rounded-circle" style="border: 2px solid var(--border-color);">
                <span class="fw-bold" style="font-size: 1.05rem; letter-spacing: -0.01em;">Naujan Tourism</span>
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center gap-1">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/explore">Explore</a></li>
                    <li class="nav-item"><a class="nav-link" href="/map">Map</a></li>
                    <% if (typeof user !== 'undefined' && user) { %>
                    <% if (user.role === 'admin') { %><li class="nav-item"><a class="nav-link" href="/admin/dashboard">Dashboard</a></li><% } %>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown" aria-expanded="false"><%= user.name || user.email %></a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="/account/settings">Account settings</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><form action="/logout" method="post" class="mb-0"><button type="submit" class="dropdown-item">Logout</button></form></li>
                        </ul>
                    </li>
                    <% } else { %>
                    <li class="nav-item"><a class="nav-link" href="/login">Login</a></li>
                    <% } %>
                    <li class="nav-item ms-2 ms-lg-3">
                        <button type="button" class="btn btn-sm btn-outline-secondary border-0 p-2 theme-toggle"
                            id="themeToggle" aria-label="Toggle dark mode" title="Toggle dark mode">
                            <i class="fas fa-moon theme-icon-dark" aria-hidden="true"></i>
                            <i class="fas fa-sun theme-icon-light d-none" aria-hidden="true"></i>
                        </button>
                    </li>
                </ul>

                <form class="d-flex ms-lg-3 position-relative" action="/search" method="GET" id="searchForm">
                    <div class="input-group">
                        <span class="input-group-text border-0" style="background: var(--accent-bg); color: var(--accent);"><i class="fas fa-search"></i></span>
                        <input class="form-control border-0" type="search" name="q" id="searchInput"
                            placeholder="Search places..." autocomplete="off" required style="background: var(--accent-bg);">
                    </div>

                    <ul class="dropdown-menu w-100 shadow-sm" id="searchResultsDropdown"
                        style="position: absolute; top: 100%; left: 0; margin-top: 0.25rem; z-index: 1050; display: none;">
                    </ul>
                </form>

            </div>
        </div>
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                const searchInput = document.getElementById('searchInput');
                const searchDropdown = document.getElementById('searchResultsDropdown');

                // Listen for every letter typed into the input
                searchInput.addEventListener('input', async (e) => {
                    const query = e.target.value.trim();

                    // If the box is empty, hide the dropdown
                    if (query.length === 0) {
                        searchDropdown.style.display = 'none';
                        return;
                    }

                    try {
                        // Ask the backend API for matches
                        const response = await fetch(`/api/search?q=${encodeURIComponent(query)}`);
                        const results = await response.json();

                        // Clear the old dropdown results
                        searchDropdown.innerHTML = '';

                        if (results.length > 0) {
                            // Loop through results and create dropdown links
                            results.forEach(spot => {
                                const li = document.createElement('li');
                                li.innerHTML = `
                                    <a class="dropdown-item d-flex justify-content-between align-items-center py-2" href="/attraction/${spot.id}">
                                        <span><strong>${spot.name}</strong></span>
                                        <span class="badge search-result-badge">${spot.category}</span>
                                    </a>
                                `;
                                searchDropdown.appendChild(li);
                            });
                            searchDropdown.style.display = 'block'; // Show dropdown
                        } else {
                            // Show "No matches" if nothing is found
                            searchDropdown.innerHTML = '<li><span class="dropdown-item text-muted">No matches found</span></li>';
                            searchDropdown.style.display = 'block';
                        }
                    } catch (error) {
                        console.error('Error fetching search results:', error);
                    }
                });

                // Hide the dropdown if the user clicks anywhere else on the page
                document.addEventListener('click', (e) => {
                    if (!searchInput.contains(e.target) && !searchDropdown.contains(e.target)) {
                        searchDropdown.style.display = 'none';
                    }
                });
            });
        </script>
    </nav>
    <script>
        (function() {
            var path = window.location.pathname;
            var pathBase = '/' + (path.split('/')[1] || '');
            document.querySelectorAll('.navbar .nav-link[href]').forEach(function(link) {
                var href = link.getAttribute('href');
                if (!href || href.includes('#')) return;
                if (href === '/') {
                    if (path === '/') link.classList.add('active-page');
                } else {
                    var hrefBase = '/' + href.split('/')[1];
                    if (pathBase === hrefBase) link.classList.add('active-page');
                }
            });
        })();
    </script>
    <main id="main-content" class="page-content">
