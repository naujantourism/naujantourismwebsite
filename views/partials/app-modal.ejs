<!-- App-themed modal for confirm, alert, and prompt (replaces native dialogs) -->
<div class="modal fade app-modal" id="appModal" tabindex="-1" aria-labelledby="appModalLabel" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content app-modal-content">
            <div class="modal-header app-modal-header border-0 pb-0">
                <h5 class="modal-title app-modal-title" id="appModalLabel">Naujan Tourism</h5>
                <button type="button" class="btn-close app-modal-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body app-modal-body pt-2">
                <p class="app-modal-message mb-0" id="appModalMessage"></p>
                <div class="app-modal-extra mt-3 d-none" id="appModalExtraWrap"></div>
                <div class="app-modal-prompt-wrap mt-3 d-none" id="appModalPromptWrap">
                    <label for="appModalInput" class="form-label small">Your response</label>
                    <input type="text" class="form-control app-modal-input" id="appModalInput" placeholder="">
                </div>
            </div>
            <div class="modal-footer app-modal-footer border-0 pt-0 flex-nowrap gap-2">
                <button type="button" class="btn btn-secondary app-modal-btn-cancel" id="appModalCancel" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary app-modal-btn-ok" id="appModalOk">OK</button>
            </div>
        </div>
    </div>
</div>
