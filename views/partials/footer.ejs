</main>
<%- include('app-modal') %>
<div id="pageLoader" class="page-loader" aria-hidden="true">
    <div class="loader-content">
        <div class="spinner-border text-light" role="status" aria-live="polite"></div>
        <span class="loader-message" id="pageLoaderMessage"><%= typeof loaderMessage !== 'undefined' ? loaderMessage : 'Loading...' %></span>
    </div>
</div>

<div id="processLoader" class="process-loader hidden" aria-live="polite" aria-busy="false">
    <div class="loader-content">
        <div class="spinner-border text-light" role="status"></div>
        <span class="loader-message" id="processLoaderMessage"></span>
    </div>
</div>

<footer class="site-footer text-center py-3 mt-5">
    <p class="mb-0">&copy; 2026 Naujan Municipal Travels. All rights reserved.</p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/app-modal.js"></script>
<script>
    (function() {
        var processEl = document.getElementById('processLoader');
        var messageEl = document.getElementById('processLoaderMessage');
        window.showProcessLoader = function(message) {
            if (!processEl || !messageEl) return;
            messageEl.textContent = message || 'Loading...';
            processEl.classList.remove('hidden');
            processEl.classList.add('active');
            processEl.setAttribute('aria-busy', 'true');
        };
        window.hideProcessLoader = function() {
            if (!processEl) return;
            processEl.classList.add('hidden');
            processEl.classList.remove('active');
            processEl.setAttribute('aria-busy', 'false');
        };
        var contactForm = document.querySelector('form[action="/contact"]');
        if (contactForm) contactForm.addEventListener('submit', function() { window.showProcessLoader('Sending message to Naujan Tourism...'); });
        var searchForm = document.getElementById('searchForm');
        if (searchForm) searchForm.addEventListener('submit', function() { window.showProcessLoader('Searching...'); });
        var loginForm = document.querySelector('form[action="/login"]');
        if (loginForm) loginForm.addEventListener('submit', function() { window.showProcessLoader('Signing in...'); });
        var registerForm = document.querySelector('form[action="/register"]');
        if (registerForm) registerForm.addEventListener('submit', function() { window.showProcessLoader('Creating account...'); });
        var logoutForm = document.querySelector('form[action="/logout"]');
        if (logoutForm) logoutForm.addEventListener('submit', function() { window.showProcessLoader('Logging out...'); });
    })();
</script>
<script src="/js/site.js"></script>
<script>
    (function() {
        function updateThemeUI() {
            var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            var iconDark = document.querySelector('.theme-icon-dark');
            var iconLight = document.querySelector('.theme-icon-light');
            if (iconDark) iconDark.classList.toggle('d-none', isDark);
            if (iconLight) iconLight.classList.toggle('d-none', !isDark);
        }
        document.getElementById('themeToggle') && document.getElementById('themeToggle').addEventListener('click', function() {
            var html = document.documentElement;
            var next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', next);
            localStorage.setItem('theme', next);
            updateThemeUI();
        });
        updateThemeUI();
    })();
</script>
</body>
</html>