<%- include('partials/header') %>

<main class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4 p-md-5">
                    <h1 class="h3 fw-bold text-center mb-4">Login or Register</h1>
                    <% if (typeof error !== 'undefined' && error) { %>
                        <div class="alert alert-danger py-2" role="alert">
                            <% if (error === 'invalid') { %>Invalid email or password.<% } %>
                            <% if (error === 'email_taken') { %>That email is already registered. Try logging in.<% } %>
                            <% if (error === 'password_length') { %>Password must be at least 6 characters.<% } %>
                            <% if (error === 'unverified') { %>Your account is not yet verified. Please check your email inbox for a verification link.<% } %>
                            <% if (error === 'invalid_token' || error === 'invalid_or_expired_token') { %>That verification link is invalid or has expired. Try logging in to request a new one.<% } %>
                            <% if (error === 'banned') { %>Your account has been banned. If you believe this is an error, please contact the site administrator.<% } %>
                            <% if (error === 'not_registered') { %>That email is not registered. Please create an account first.<% } %>
                            <% if (error === 'reset_invalid' || error === 'reset_invalid_or_expired') { %>That password reset link is invalid or has expired. Please request a new one.<% } %>
                            <% if (error === 'error') { %>Something went wrong. Please try again.<% } %>
                        </div>
                    <% } %>

                    <% if (typeof success !== 'undefined' && success) { %>
                        <div class="alert alert-success py-2" role="alert">
                            <% if (success === 'check_email') { %>Account created! Please check your email for a verification link before logging in.<% } %>
                            <% if (success === 'verified') { %>Your email has been verified. You can now log in.<% } %>
                            <% if (success === 'already_verified') { %>Your email is already verified. You can log in below.<% } %>
                            <% if (success === 'reset_sent') { %>Password reset link sent. Please check your email.<% } %>
                            <% if (success === 'reset_done') { %>Your password has been reset. You can now log in.<% } %>
                        </div>
                    <% } %>

                    <ul class="nav nav-tabs mb-4" id="authTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="login-tab" data-bs-toggle="tab" data-bs-target="#login-pane" type="button" role="tab">Login</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="register-tab" data-bs-toggle="tab" data-bs-target="#register-pane" type="button" role="tab">Register</button>
                        </li>
                    </ul>

                    <div class="tab-content" id="authTabContent">
                        <div class="tab-pane fade show active" id="login-pane" role="tabpanel">
                            <form action="/login" method="post">
                                <input type="hidden" name="redirect" value="<%= typeof redirect !== 'undefined' ? redirect : '/' %>">
                                <div class="mb-3">
                                    <label for="login-email" class="form-label">Email</label>
                                    <input type="email" class="form-control" id="login-email" name="email" required autocomplete="email">
                                </div>
                                <div class="mb-3">
                                    <label for="login-password" class="form-label">Password</label>
                                    <input type="password" class="form-control" id="login-password" name="password" required autocomplete="current-password">
                                </div>
                                <button type="submit" class="btn btn-primary w-100 mb-2">Login</button>
                                <div class="text-center">
                                    <a href="/forgot-password" class="small text-decoration-none">Forgot your password?</a>
                                </div>
                            </form>
                        </div>
                        <div class="tab-pane fade" id="register-pane" role="tabpanel">
                            <form action="/register" method="post">
                                <input type="hidden" name="redirect" value="<%= typeof redirect !== 'undefined' ? redirect : '/' %>">
                                <div class="mb-3">
                                    <label for="reg-name" class="form-label">Name</label>
                                    <input type="text" class="form-control" id="reg-name" name="name" placeholder="Your display name" autocomplete="name">
                                </div>
                                <div class="mb-3">
                                    <label for="reg-email" class="form-label">Email</label>
                                    <input type="email" class="form-control" id="reg-email" name="email" required autocomplete="email">
                                </div>
                                <div class="mb-3">
                                    <label for="reg-password" class="form-label">Password (min 6 characters)</label>
                                    <input type="password" class="form-control" id="reg-password" name="password" required minlength="6" autocomplete="new-password">
                                </div>
                                <button type="submit" class="btn btn-outline-primary w-100">Register</button>
                            </form>
                        </div>
                    </div>

                    <p class="text-muted small text-center mt-4 mb-0">
                        <a href="/" class="text-decoration-none">← Back to home</a>
                        <% if (typeof redirect !== 'undefined' && redirect && redirect !== '/') { %>
                            &nbsp;·&nbsp;<a href="<%= redirect %>" class="text-decoration-none">Go to dashboard</a>
                        <% } %>
                    </p>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include('partials/footer') %>
