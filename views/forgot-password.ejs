<%- include('partials/header') %>

<main class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4 p-md-5">
                    <h1 class="h3 fw-bold text-center mb-4">Forgot your password?</h1>
                    <p class="text-muted small mb-4 text-center">
                        Enter the email address you used to register. If it is registered, we will send you a link to reset your password.
                    </p>
                    <form action="/forgot-password" method="post">
                        <div class="mb-3">
                            <label for="fp-email" class="form-label">Email</label>
                            <input type="email" class="form-control" id="fp-email" name="email" required autocomplete="email">
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Send reset link</button>
                    </form>
                    <p class="text-muted small text-center mt-4 mb-0">
                        <a href="/login" class="text-decoration-none">← Back to login</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include('partials/footer') %>

