<%- include('partials/header') %>

<section class="auth-wrapper container">
    <div class="row justify-content-center w-100">
        <div class="col-md-10 col-lg-7 col-xl-5">
            <div class="auth-card">
                <div class="text-center mb-4">
                    <span class="badge rounded-pill px-3 py-2 mb-3" style="background: var(--accent-bg); color: var(--accent); font-weight: 600;">
                        <i class="fas fa-key me-1"></i> Password Reset
                    </span>
                    <h1 class="h3 fw-bold">Forgot your password?</h1>
                </div>
                    <p class="small mb-4 text-center" style="color: var(--text-secondary);">
                        Enter the email address you used to register. If it is registered, we will send you a link to reset your password.
                    </p>
                    <form action="/forgot-password" method="post">
                        <div class="mb-3">
                            <label for="fp-email" class="form-label">Email</label>
                            <input type="email" class="form-control" id="fp-email" name="email" required autocomplete="email">
                        </div>
                        <button type="submit" class="btn btn-primary w-100 rounded-pill">Send reset link</button>
                    </form>
                    <p class="small text-center mt-4 mb-0" style="color: var(--text-secondary);">
                        <a href="/login" class="text-decoration-none" style="color: var(--accent);"><i class="fas fa-arrow-left me-1"></i> Back to login</a>
                    </p>
            </div>
        </div>
    </div>
</section>

<%- include('partials/footer') %>

