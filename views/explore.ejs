<%- include('partials/header') %>

    <div class="explore-hero-gradient py-5 mb-5 text-white text-center reveal-on-scroll">
        <h1 class="fw-bold">Explore Naujan</h1>
        <p class="lead">Find your next adventure in our historic town.</p>
    </div>

    <div class="container mb-5">

        <% if (title.includes('Search Results')) { %>
            <h3 class="mb-4">
                <%= title %>
            </h3>
            <% } %>

                <div class="d-flex justify-content-center flex-wrap mb-5 gap-2 reveal-on-scroll" id="category-filters">
                    <button class="btn btn-primary rounded-pill filter-btn px-4" data-filter="all">All</button>
                    <button class="btn btn-outline-danger rounded-pill filter-btn px-4" data-filter="favorites"
                        id="favoritesFilterBtn" title="<%= typeof user !== 'undefined' && user ? 'Show saved places' : 'Log in to see your favorites' %>">
                        <i class="fa-solid fa-heart me-1" aria-hidden="true"></i>
                        Favorites <span class="badge text-bg-light ms-1" id="favoritesCount">0</span>
                    </button>
                    <% (categories || []).forEach(function(c) { %>
                    <button class="btn btn-outline-primary rounded-pill filter-btn px-4" data-filter="<%= c %>"><%= c %></button>
                    <% }); %>
                </div>

                <div class="row" id="spots-container">
                    <% if (attractions.length> 0) { %>
                        <% attractions.forEach(function(spot, index) { %>

                            <div class="col-12 mb-5 spot-item reveal-on-scroll <%= index % 2 === 0 ? 'reveal-from-left' : 'reveal-from-right' %>" data-category="<%= spot.category %>"
                                data-id="<%= spot.id %>">

                                <div class="row align-items-center g-4 <%= index % 2 === 0 ? '' : 'flex-row-reverse' %>">
                                    <div class="col-md-6">
                                        <img src="<%= typeof imageBaseUrl !== 'undefined' ? imageBaseUrl : '' %><%= spot.image %>" class="img-fluid rounded-3 shadow"
                                            alt="<%= spot.name %>" loading="lazy" decoding="async"
                                            style="width: 100%; height: 400px; object-fit: cover;">
                                    </div>
                                    <div class="col-md-6 p-4 p-lg-5">
                                        <span class="text-primary fw-bold text-uppercase">
                                            <%= spot.category %>
                                        </span>
                                        <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
                                            <div>
                                                <h2 class="display-5 fw-bold mt-2 mb-2">
                                                    <%= spot.name %>
                                                </h2>
                                                <% if (spot.uniqueHighlight) { %>
                                                    <span class="unique-highlight-pill mb-3">
                                                        <%= spot.uniqueHighlight %>
                                                    </span>
                                                    <% } %>
                                            </div>
                                            <button type="button"
                                                class="btn btn-sm btn-outline-danger rounded-pill px-3 favorite-btn"
                                                data-favorite-id="<%= spot.id %>"
                                                data-global-fav="<%= spot.stats ? spot.stats.favoritesCount : 0 %>"
                                                aria-pressed="false" title="Save to favorites">
                                                <i class="fa-regular fa-heart me-1" aria-hidden="true"></i>
                                                <span class="favorite-btn-label">Save (<%= spot.stats ?
                                                        spot.stats.favoritesCount : 0 %>)</span>
                                            </button>
                                        </div>
                                        <p class="lead text-muted" style="max-width: 36rem;">
                                            <%= spot.desc %>
                                        </p>
                                        <a href="/attraction/<%= spot.id %>"
                                            class="btn btn-primary rounded-pill px-4">View Map & Details</a>
                                    </div>
                                </div>
                            </div>
                            <% }); %>
                                <% } else { %>
                                    <div class="col-12 text-center py-5">
                                        <h3 class="text-muted">No tourist spots found matching your search.</h3>
                                        <a href="/explore" class="btn btn-outline-primary mt-3">View All Spots</a>
                                    </div>
                                    <% } %>
                </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const filterBtns = document.querySelectorAll('.filter-btn');
            const spots = document.querySelectorAll('.spot-item');

            function getFavorites() {
                if (window.__userFavorites && Array.isArray(window.__userFavorites)) return window.__userFavorites;
                return [];
            }

            function updateFavoriteUI() {
                const favs = new Set(getFavorites());
                const favCountEl = document.getElementById('favoritesCount');
                if (favCountEl) favCountEl.textContent = String(favs.size);
            }

            function applyFilter(filterValue) {
                const favs = new Set(getFavorites());
                spots.forEach(spot => {
                    const category = spot.getAttribute('data-category');
                    const id = spot.getAttribute('data-id');
                    const shouldShow =
                        filterValue === 'all' ||
                        (filterValue === 'favorites' && favs.has(id)) ||
                        category === filterValue;

                    if (shouldShow) {
                        spot.style.display = 'block';
                        spot.style.animation = 'fadeIn 0.5s';
                    } else {
                        spot.style.display = 'none';
                    }
                });
            }

            filterBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    // 1. Update button colors (make clicked button solid, others outline)
                    filterBtns.forEach(b => {
                        b.classList.remove('btn-primary');
                        b.classList.add(b.getAttribute('data-filter') === 'favorites' ? 'btn-outline-danger' : 'btn-outline-primary');
                    });
                    btn.classList.remove(btn.getAttribute('data-filter') === 'favorites' ? 'btn-outline-danger' : 'btn-outline-primary');
                    btn.classList.add('btn-primary');

                    // 2. Get the category we want to filter by
                    const filterValue = btn.getAttribute('data-filter');

                    // 3. Loop through all spots and hide/show them
                    applyFilter(filterValue);
                });
            });

            // Keep favorites count and filter results in sync with global favorites changes
            window.addEventListener('favorites:changed', () => {
                updateFavoriteUI();
                const activeFilter = document.querySelector('.filter-btn.btn-primary');
                const activeValue = activeFilter ? activeFilter.getAttribute('data-filter') : 'all';
                applyFilter(activeValue || 'all');
            });

            updateFavoriteUI();
        });
    </script>

    <style>
        /* Small animation for smooth filtering */
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>


    <%- include('partials/footer') %>
