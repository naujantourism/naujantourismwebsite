<%- include('../partials/header') %>

    <div class="bg-primary py-5 mb-4 text-white text-center analytics-hero reveal-on-scroll">
        <h1 class="fw-bold">Analytics Dashboard</h1>
        <p class="lead mb-0">Attraction page visits — see what’s most popular.</p>
    </div>

    <div class="container mb-5 dashboard-page">
        <div class="row g-4 mb-4 align-items-center">
            <div class="col-md-8 reveal-on-scroll">
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center py-4">
                        <p class="text-muted text-uppercase small mb-1">Total page views (all attractions)</p>
                        <h2 class="display-4 fw-bold text-primary mb-0">
                            <%= totalVisits %>
                        </h2>
                        <% if (typeof lastResetAt !=='undefined' && lastResetAt) { %>
                            <p class="text-muted small mt-2 mb-0">Counts reset: <%= new
                                    Date(lastResetAt).toLocaleDateString() %> — auto-reset every 30 days</p>
                            <% } %>
                    </div>
                </div>
            </div>
            <div class="col-md-4 text-md-end reveal-on-scroll">
                <a href="/admin/attractions" class="btn btn-outline-primary me-2">
                    <i class="fas fa-map-marker-alt me-1" aria-hidden="true"></i> Manage Attractions
                </a>
                <a href="/admin/reviews" class="btn btn-outline-secondary me-2">
                    <i class="fas fa-comments me-1" aria-hidden="true"></i> Moderate Reviews
                </a>
                <a href="/admin/reportacc" class="btn btn-outline-secondary me-2">
                    <i class="fas fa-flag me-1" aria-hidden="true"></i> Reported Comments
                </a>
                <form action="/admin/dashboard/reset-favs" method="post" class="d-inline me-2"
                    onsubmit="var f=this; appConfirm('Reset all favorites and ratings? This cannot be undone.', function(){ f.submit(); }); return false;">
                    <button type="submit" class="btn btn-outline-warning">
                        <i class="fas fa-star-half-stroke me-1" aria-hidden="true"></i> Reset feedback
                    </button>
                </form>
                <form action="/admin/dashboard/reset" method="post" class="d-inline"
                    onsubmit="var f=this; appConfirm('Reset all visit counts? This cannot be undone.', function(){ f.submit(); }); return false;">
                    <button type="submit" class="btn btn-outline-danger">
                        <i class="fas fa-rotate-left me-1" aria-hidden="true"></i> Reset visits
                    </button>
                </form>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-5 reveal-on-scroll">
            <div class="card-body py-4">
                <h3 class="h5 fw-bold mb-3">Visits Overview</h3>
                <div class="chart-container">
                    <canvas id="visitsChart"></canvas>
                </div>
            </div>
        </div>

        <h2 class="h4 fw-bold mb-3">Most visited attractions</h2>
        <p class="text-muted mb-4">Sorted by number of visits. Each time someone opens an attraction page, that visit is
            counted.</p>

        <% const top=attractionsWithVisits.slice(0, 3); %>
            <% if (top.some(a=> a.visits > 0)) { %>
                <div class="row g-3 mb-4">
                    <% top.forEach((attraction, i)=> { %>
                        <div class="col-md-4 reveal-on-scroll">
                            <div class="card h-100 border-0 shadow-sm overflow-hidden">
                                <div class="position-relative">
                                    <img src="<%= attraction.image %>" class="card-img-top" alt="<%= attraction.name %>"
                                        style="height: 160px; object-fit: cover;">
                                    <span class="position-absolute top-0 start-0 m-2 badge bg-dark fs-6">#<%= i + 1 %>
                                    </span>
                                </div>
                                <div class="card-body">
                                    <h5 class="card-title fw-bold">
                                        <%= attraction.name %>
                                    </h5>
                                    <span class="badge bg-secondary mb-2">
                                        <%= attraction.category %>
                                    </span>
                                    <p class="card-text mb-0"><strong>
                                            <%= attraction.visits %>
                                        </strong> visits</p>
                                    <a href="/attraction/<%= attraction.id %>"
                                        class="btn btn-sm btn-outline-primary mt-2">View page</a>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                </div>
                <% } %>

                    <div class="card border-0 shadow-sm reveal-on-scroll">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0 dashboard-table">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-3">#</th>
                                        <th>Attraction</th>
                                        <th>Category</th>
                                        <th class="text-end">Favs</th>
                                        <th class="text-end">Rating</th>
                                        <th class="text-end pe-3">Visits</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% attractionsWithVisits.forEach((attraction, index)=> { %>
                                        <tr>
                                            <td class="ps-3 fw-semibold text-muted">
                                                <%= index + 1 %>
                                            </td>
                                            <td>
                                                <a href="/attraction/<%= attraction.id %>"
                                                    class="text-decoration-none fw-medium">
                                                    <%= attraction.name %>
                                                </a>
                                            </td>
                                            <td><span class="badge bg-light text-dark">
                                                    <%= attraction.category %>
                                                </span></td>
                                            <td class="text-end fw-semibold">
                                                <%= attraction.stats ? attraction.stats.favoritesCount : 0 %>
                                            </td>
                                            <td class="text-end fw-semibold">
                                                <%= attraction.stats ? attraction.stats.avgRating : 0 %> / 5 (<%=
                                                        attraction.stats ? attraction.stats.ratingCount : 0 %>)
                                            </td>
                                            <td class="text-end pe-3 fw-semibold">
                                                <%= attraction.visits %>
                                            </td>
                                        </tr>
                                        <% }); %>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="mt-4 text-muted small">
                        <p class="mb-0">Visit and feedback counts are stored securely in <strong>Firebase Realtime
                                Database</strong> and persist across
                            server deployments.</p>
                    </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Safely inject the EJS data into JavaScript
            const chartData = <%- JSON.stringify(attractionsWithVisits || []) %>;

            // Extract labels (names) and data (visit counts)   
            const labels = chartData.map(item => item.name);
            const data = chartData.map(item => item.visits);

            const ctx = document.getElementById('visitsChart').getContext('2d');

            // Helper function to figure out the right colors based on the current theme
            function getThemeColors() {
                const isDarkMode = document.documentElement.getAttribute('data-theme') === 'dark';
                return {
                    textColor: isDarkMode ? '#adb5bd' : '#6c757d',
                    gridColor: isDarkMode ? 'rgba(255,255,255,0.1)' : 'rgba(0,0,0,0.1)'
                };
            }

            let colors = getThemeColors();

            const visitsChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Total Visits',
                        data: data,
                        backgroundColor: 'rgba(13, 110, 253, 0.8)',
                        borderColor: '#0d6efd',
                        borderWidth: 1,
                        borderRadius: 4,
                        hoverBackgroundColor: '#0a58ca'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: { padding: 10, cornerRadius: 8 }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: { color: colors.textColor, precision: 0 },
                            grid: { color: colors.gridColor }
                        },
                        x: {
                            ticks: { color: colors.textColor },
                            grid: { display: false }
                        }
                    }
                }
            });

            // Listen for dark mode toggle clicks so the chart updates instantly
            const themeToggleBtn = document.querySelector('.theme-toggle');
            if (themeToggleBtn) {
                themeToggleBtn.addEventListener('click', () => {
                    // Wait 50ms to let the HTML tag update its data-theme attribute
                    setTimeout(() => {
                        const newColors = getThemeColors();
                        visitsChart.options.scales.y.ticks.color = newColors.textColor;
                        visitsChart.options.scales.y.grid.color = newColors.gridColor;
                        visitsChart.options.scales.x.ticks.color = newColors.textColor;
                        visitsChart.update();
                    }, 50);
                });
            }
        });
    </script>

    <%- include('../partials/footer') %>
