<%- include('../partials/header') %>

<div class="bg-primary py-4 mb-4 text-white">
    <div class="container">
        <h1 class="h3 fw-bold mb-0">Manage Attractions</h1>
        <p class="mb-0 opacity-90">Add, edit, delete, or set active/inactive.</p>
    </div>
</div>

<div class="container mb-5">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <a href="/admin/dashboard" class="btn btn-outline-secondary">&larr; Dashboard</a>
        <a href="/admin/attractions/add" class="btn btn-primary">+ Add Attraction</a>
    </div>

    <div class="card border-0 shadow-sm mb-4 admin-attractions-filter-card">
        <div class="card-body p-3 p-md-4">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-md-5 col-lg-4">
                    <label for="attractionsSearch" class="form-label small fw-semibold mb-1">Search</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-search text-muted"></i></span>
                        <input type="text" class="form-control" id="attractionsSearch" placeholder="Search by name or category..." autocomplete="off">
                    </div>
                </div>
                <div class="col-12 col-md-4 col-lg-3">
                    <label for="attractionsCategory" class="form-label small fw-semibold mb-1">Category</label>
                    <select class="form-select" id="attractionsCategory">
                        <option value="">All categories</option>
                        <% (categories || []).forEach(function(c) { %>
                        <option value="<%= c %>"><%= c %></option>
                        <% }); %>
                    </select>
                </div>
                <div class="col-12 col-md-3 col-lg-2">
                    <label for="attractionsStatus" class="form-label small fw-semibold mb-1">Status</label>
                    <select class="form-select" id="attractionsStatus">
                        <option value="">All status</option>
                        <option value="active">Active</option>
                        <option value="inactive">Inactive</option>
                    </select>
                </div>
                <div class="col-12 col-md-auto">
                    <button type="button" class="btn btn-outline-secondary" id="attractionsFilterReset" title="Clear filters">
                        <i class="fas fa-times me-1"></i>Clear
                    </button>
                </div>
            </div>
            <p class="small text-muted mb-0 mt-2" id="attractionsFilterCount">
                Showing <strong id="attractionsVisibleCount">0</strong> of <strong id="attractionsTotalCount"><%= (attractions || []).length %></strong> attractions
            </p>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">Name</th>
                        <th>Category</th>
                        <th>Status</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody id="attractionsTableBody">
                    <% (attractions || []).forEach(function(a) { %>
                    <tr class="attraction-row" data-name="<%= (a.name || '').toLowerCase() %>" data-category="<%= a.category || '' %>" data-status="<%= a.active !== false ? 'active' : 'inactive' %>">
                        <td class="ps-3">
                            <a href="/attraction/<%= a.id %>" class="text-decoration-none fw-medium" target="_blank"><%= a.name %></a>
                        </td>
                        <td><span class="badge bg-light text-dark"><%= a.category %></span></td>
                        <td>
                            <% if (a.active !== false) { %>
                                <span class="badge bg-success">Active</span>
                            <% } else { %>
                                <span class="badge bg-secondary">Inactive</span>
                            <% } %>
                        </td>
                        <td class="text-end pe-3">
                            <a href="/admin/attractions/edit/<%= a.id %>" class="btn btn-sm btn-outline-primary me-1">Edit</a>
                            <form action="/admin/attractions/toggle-active/<%= a.id %>" method="post" class="d-inline me-1">
                                <button type="submit" class="btn btn-sm btn-outline-warning">
                                    <%= a.active !== false ? 'Set Inactive' : 'Set Active' %>
                                </button>
                            </form>
                            <form action="/admin/attractions/delete/<%= a.id %>" method="post" class="d-inline"
                                onsubmit="var f=this; appConfirm('Delete this attraction? This cannot be undone.', function(){ f.submit(); }); return false;">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
        <div id="attractionsNoResults" class="card-body text-center py-5 text-muted" style="display: none;">
            <i class="fas fa-search fa-2x mb-2 opacity-50"></i>
            <p class="mb-0">No attractions match your search or filters.</p>
        </div>
    </div>
</div>

<script>
(function() {
    var searchEl = document.getElementById('attractionsSearch');
    var categoryEl = document.getElementById('attractionsCategory');
    var statusEl = document.getElementById('attractionsStatus');
    var resetBtn = document.getElementById('attractionsFilterReset');
    var rows = document.querySelectorAll('.attraction-row');
    var tableBody = document.getElementById('attractionsTableBody');
    var noResults = document.getElementById('attractionsNoResults');
    var visibleCountEl = document.getElementById('attractionsVisibleCount');
    var totalCountEl = document.getElementById('attractionsTotalCount');

    function applyFilters() {
        var q = (searchEl.value || '').trim().toLowerCase();
        var cat = (categoryEl.value || '').trim();
        var status = (statusEl.value || '').trim();
        var visible = 0;

        rows.forEach(function(row) {
            var name = row.getAttribute('data-name') || '';
            var rowCat = row.getAttribute('data-category') || '';
            var rowStatus = row.getAttribute('data-status') || '';
            var matchSearch = !q || name.indexOf(q) !== -1 || rowCat.toLowerCase().indexOf(q) !== -1;
            var matchCat = !cat || rowCat === cat;
            var matchStatus = !status || rowStatus === status;
            var show = matchSearch && matchCat && matchStatus;
            row.style.display = show ? '' : 'none';
            if (show) visible++;
        });

        visibleCountEl.textContent = visible;
        tableBody.style.display = visible > 0 ? '' : 'none';
        var tableWrap = tableBody.closest('.table-responsive');
        if (tableWrap) tableWrap.style.display = visible > 0 ? '' : 'none';
        noResults.style.display = visible > 0 ? 'none' : 'block';
    }

    searchEl.addEventListener('input', applyFilters);
    searchEl.addEventListener('keyup', applyFilters);
    categoryEl.addEventListener('change', applyFilters);
    statusEl.addEventListener('change', applyFilters);

    resetBtn.addEventListener('click', function() {
        searchEl.value = '';
        categoryEl.value = '';
        statusEl.value = '';
        applyFilters();
        searchEl.focus();
    });

    applyFilters();
})();
</script>

<%- include('../partials/footer') %>
