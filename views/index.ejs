<%- include('partials/header') %>

<header class="hero-section position-relative overflow-hidden">
    
    <div id="heroCarousel" class="carousel slide carousel-fade position-absolute top-0 start-0 w-100 h-100" data-bs-ride="carousel">
        <div class="carousel-inner w-100 h-100">
            <div class="carousel-item active h-100">
                <div class="hero-bg-img" style="background-image: url('<%= typeof imageBaseUrl !== "undefined" ? imageBaseUrl : "" %>/images/lake.jpg');"></div>
            </div>
            <div class="carousel-item h-100">
                <div class="hero-bg-img" style="background-image: url('<%= typeof imageBaseUrl !== "undefined" ? imageBaseUrl : "" %>/images/simbahan/main.jpg');"></div>
            </div>
            <div class="carousel-item h-100">
                <div class="hero-bg-img" style="background-image: url('<%= typeof imageBaseUrl !== "undefined" ? imageBaseUrl : "" %>/images/liwasang.jpg');"></div>
            </div>
            <div class="carousel-item h-100">
                <div class="hero-bg-img" style="background-image: url('<%= typeof imageBaseUrl !== "undefined" ? imageBaseUrl : "" %>/images/333-steps.jpg');"></div>
            </div>
        </div>
    </div>

    <div class="hero-overlay position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center text-center">
        <div class="container text-white z-2 reveal-on-scroll">
            <h5 class="text-uppercase letter-spacing-2 mb-3">Welcome to Oriental Mindoro</h5>
            <h1 class="hero-title">Discover Naujan</h1>
            <p class="lead mb-4 fs-4">“Naujan: Experience Nature, Culture, and Adventure.”</p>
            <a href="/explore" class="btn btn-explore">Explore Now</a>
        </div>
    </div>

    <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark opacity-50 z-1"></div>

</header>

<section class="py-5 text-center container reveal-on-scroll">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h2 class="section-title text-primary">Love Naujan</h2>
            <p class="lead text-muted mt-3">
                Experience the serene beauty of Naujan Lake, walk through the historic ruins of Bancuro, 
                and taste the local flavors of Mindoro. Naujan is your gateway to nature and history.
            </p>
        </div>
    </div>
</section>

<section class="py-5 bg-light">
    <div class="container">
        <h3 class="mb-5 text-center fw-bold">Top Attractions</h3>
        <p class="text-center text-muted small mb-4">Most visited places — based on recent page views</p>
        <div class="row g-4">
            <% featured.forEach(function(spot, index) { %>
                <div class="col-md-4 d-flex align-items-stretch reveal-on-scroll">
                    <div class="card h-100 border-0 shadow-sm hover-card w-100">
                        <div class="position-relative">
                            <img src="<%= typeof imageBaseUrl !== 'undefined' ? imageBaseUrl : '' %><%= spot.image %>" class="card-img-top" alt="<%= spot.name %>" style="height: 250px; object-fit: cover;">
                            <% if (spot.visits !== undefined && spot.visits > 0 && index === 0) { %>
                                <span class="position-absolute top-0 start-0 m-2 badge bg-warning text-dark">Most visited</span>
                            <% } %>
                            <% if (spot.visits !== undefined && spot.visits > 0) { %>
                                <span class="position-absolute top-0 end-0 m-2 badge bg-dark"><%= spot.visits %> views</span>
                            <% } %>
                        </div>
                        
                        <div class="card-body text-center p-4 d-flex flex-column">
                            
                            <div class="mb-2 d-flex flex-column justify-content-center" style="height: 80px;">
                                <div>
                                    <span class="badge bg-primary mb-2"><%= spot.category %></span>
                                    <h4 class="card-title fw-bold m-0"><%= spot.name %></h4>
                                </div>
                            </div>
        
                            <p class="card-text text-muted small mb-4" 
                               style="height: 60px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical;">
                               <%= spot.desc %>
                            </p>
                            
                            <div class="mt-auto">
                                <a href="/attraction/<%= spot.id %>" class="btn btn-primary rounded-pill px-4">View Map & Details</a>
                            </div>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
    </div>
</section>

<section class="py-5 text-center container reveal-on-scroll">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h2 class="section-title text-primary">About Naujan</h2>
            <p class="lead text-muted mt-3">
                Naujan is a first-class municipality in Oriental Mindoro, rich in culture, history, and natural wonders. 
                Whether you are looking for a peaceful retreat by the lake or a journey through historic ruins, 
                Naujan offers an unforgettable experience.
            </p>
        </div>
    </div>
</section>

<section id="contact" class="py-5 bg-light reveal-on-scroll">
    <div class="container">
        <div class="row justify-content-center align-items-start g-4 g-lg-5">
            <div class="col-lg-6 col-xl-5">
                <h2 class="section-title text-primary mb-3">Contact Naujan Tourism</h2>
                <div class="border-bottom border-primary border-2 mb-3" style="width: 60px;"></div>
                <p class="text-muted mb-4">Send us a message and we’ll get back to you as soon as we can.</p>
                <% if (typeof contactSuccess !== 'undefined' && contactSuccess) { %>
                    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
                        <i class="fas fa-check-circle me-2"></i>Your message has been sent. We’ll be in touch soon.
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>
                <% if (typeof contactError !== 'undefined' && contactError) { %>
                    <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i>Something went wrong. Please try again or email us directly.
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>
                <form action="/contact" method="post" class="card border-0 shadow-sm p-3 contact-form-card">
                    <div class="mb-2">
                        <label for="contact-name" class="form-label small mb-1">Your name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control form-control-sm" id="contact-name" name="name" required maxlength="200" placeholder="Juan Dela Cruz" value="">
                    </div>
                    <div class="mb-2">
                        <label for="contact-email" class="form-label small mb-1">Your email <span class="text-danger">*</span></label>
                        <input type="email" class="form-control form-control-sm" id="contact-email" name="email" required placeholder="you@example.com" value="">
                    </div>
                    <div class="mb-3">
                        <label for="contact-message" class="form-label small mb-1">Message <span class="text-danger">*</span></label>
                        <textarea class="form-control form-control-sm" id="contact-message" name="message" rows="3" required maxlength="5000" placeholder="Your message..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary btn-sm rounded-pill px-3">
                        <i class="fas fa-paper-plane me-1"></i>Send message
                    </button>
                </form>
            </div>
            <div class="col-lg-6 col-xl-5 text-center text-lg-start">
                <h2 class="section-title text-primary mb-3">Connect With Us</h2>
                <div class="border-bottom border-primary border-2 mb-3 mx-lg-0 mx-auto" style="width: 60px;"></div>
                <p class="text-muted mb-4">Follow us on social media for updates and inspiration.</p>
                <div class="d-flex flex-wrap gap-2 justify-content-center justify-content-lg-start">
                    <a href="https://web.facebook.com/NaujanTourism" target="_blank" rel="noopener noreferrer" class="btn btn-primary rounded-pill px-4 py-2 shadow-sm">
                        <i class="fab fa-facebook-f me-2"></i> Facebook
                    </a>
                    <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="btn rounded-pill px-4 py-2 shadow-sm" style="background: #E1306C; border-color: #E1306C; color: #fff;">
                        <i class="fab fa-instagram me-2"></i> Instagram
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
#contact .contact-form-card { max-width: 380px; }
</style>

<%- include('partials/footer') %>