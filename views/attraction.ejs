<%- include('partials/header') %>

<link href="https://api.mapbox.com/mapbox-gl-js/v2.14.1/mapbox-gl.css" rel="stylesheet">
<style>
    #map {
        width: 100%;
        height: 400px;
        border-radius: 10px;
    }
    .marker {
        background-image: url('https://docs.mapbox.com/mapbox-gl-js/assets/custom_marker.png');
        background-size: cover;
        width: 30px;
        height: 30px;
        cursor: pointer;
    }
</style>

<div class="container my-5 reveal-on-scroll">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <li class="breadcrumb-item"><a href="/explore">Explore</a></li>
            <li class="breadcrumb-item active" aria-current="page">
                <%= attraction.name %>
            </li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-lg-7 reveal-on-scroll">

            <span class="badge rounded-pill px-3 py-1 mb-2 fs-6" style="background: var(--accent-bg); color: var(--accent); font-weight: 600;">
                <%= attraction.category %>
            </span>
            <img src="<%= typeof imageBaseUrl !== 'undefined' ? imageBaseUrl : '' %><%= attraction.image %>" class="img-fluid rounded shadow mb-4" alt="<%= attraction.name %>"
                decoding="async" style="width: 100%; max-height: 500px; object-fit: cover;">

            <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
                <div>
                    <h1 class="display-4 fw-bold mb-2">
                        <%= attraction.name %>
                    </h1>

                    <% if (attraction.uniqueHighlight) { %>
                        <div class="mt-1 mb-2">
                            <span class="unique-highlight-pill attraction-hero-pill">
                                <%= attraction.uniqueHighlight %>
                            </span>
                        </div>
                    <% } %>
                </div>
                
                <button type="button" class="btn btn-outline-danger rounded-pill px-3 favorite-btn"
                    data-favorite-id="<%= attraction.id %>"
                    data-global-fav="<%= stats ? stats.favoritesCount : 0 %>" aria-pressed="false"
                    title="Save to favorites">
                    <i class="fa-regular fa-heart me-1" aria-hidden="true"></i>
                    <span class="favorite-btn-label">Save (<%= stats ? stats.favoritesCount : 0 %>)</span>
                </button>
                
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="rating-container" data-id="<%= attraction.id %>" style="cursor: pointer;">
                        <% const avg = stats && stats.avgRating ? Math.round(stats.avgRating) : 0; %>
                        <% for (let i = 1; i <= 5; i++) { %>
                            <i class="<%= i <= avg ? 'fa-solid text-warning' : 'fa-regular' %> fa-star rating-star fs-4"
                                data-value="<%= i %>"></i>
                        <% } %>
                        <span class="rating-label small text-muted ms-2">
                            <% if (stats && stats.ratingCount > 0) { %>
                                <%= stats.avgRating %> / 5 (<%= stats.ratingCount %> reviews)
                            <% } else if (typeof user !== 'undefined' && user) { %>
                                Rate this spot
                            <% } else { %>
                                Log in to rate
                            <% } %>
                        </span>
                    </div>
                </div>
            </div>

            <% 
            const hasRoomsOrMenuTop = (attraction.rooms && attraction.rooms.length) || (attraction.menu && attraction.menu.length) || (attraction.addons && attraction.addons.length);
            const hasRentTop = attraction.rent && attraction.rent.length;
            const showPackagesButton = hasRoomsOrMenuTop || hasRentTop;
            %>
            
            <% if (showPackagesButton) { %>
                <div class="mb-3">
                    <button type="button" class="btn btn-primary btn-sm rounded-pill px-3 shadow-sm"
                        data-bs-toggle="modal" data-bs-target="#accommodationInfoModal">
                        View
                        <% if (hasRentTop && !hasRoomsOrMenuTop) { %>
                            Rent
                        <% } else if (attraction.rooms && attraction.addons) { %>
                            Rooms & Add-ons
                        <% } else if (attraction.rooms && attraction.menu) { %>
                            Rooms & Menu
                        <% } else if (attraction.rooms) { %>
                            Rooms
                        <% } else if (attraction.addons) { %>
                            Add-ons
                        <% } else { %>
                            Menu
                        <% } %>
                    </button>
                </div>
            <% } %>

            <% if (attraction.gallery && attraction.gallery.length > 0) { %>
                <div class="mt-5 reveal-on-scroll">
                    <h4 class="fw-bold mb-3">Photo Gallery</h4>
                    <div class="row g-2">
                        <% attraction.gallery.forEach(function(photo) { %>
                            <div class="col-md-4 col-6">
                                <div class="overflow-hidden rounded shadow-sm">
                                    <a data-fslightbox="gallery" href="<%= typeof imageBaseUrl !== 'undefined' ? imageBaseUrl : '' %><%= photo %>">
                                        <img src="<%= typeof imageBaseUrl !== 'undefined' ? imageBaseUrl : '' %><%= photo %>" class="img-fluid gallery-img"
                                            alt="Gallery Photo for <%= attraction.name %>"
                                            loading="lazy" decoding="async"
                                            style="width: 100%; height: 160px; object-fit: cover; transition: transform 0.3s ease;">
                                    </a>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                </div>
            <% } %>

            <p class="lead mt-3" style="text-align: justify; max-width: 44rem;">
                <%= attraction.desc %>
            </p>

            <% if (attraction.openingHours || attraction.entranceFees || attraction.visitorTips) { %>
                <div class="mt-4 info-card visitor-info-card reveal-on-scroll">
                    <h5 class="fw-bold mb-3"><i class="fas fa-info-circle me-2 text-primary"></i>Visitor Information</h5>
                    <ul class="list-unstyled mb-0">
                        <% if (attraction.openingHours) { %>
                            <li class="mb-2">
                                <strong><i class="far fa-clock me-2 text-secondary"></i>Hours:</strong>
                                <%= attraction.openingHours %>
                            </li>
                        <% } %>

                        <% if (attraction.entranceFees) { %>
                            <li class="mb-2">
                                <strong><i class="fas fa-ticket-alt me-2 text-secondary"></i>Fees:</strong>
                                <%= attraction.entranceFees %>
                            </li>
                        <% } %>

                        <% if (attraction.visitorTips) { %>
                            <li class="mb-0">
                                <strong><i class="far fa-lightbulb me-2 text-warning"></i>Tips:</strong>
                                <%= attraction.visitorTips %>
                            </li>
                        <% } %>
                    </ul>
                </div>
            <% } %>

            <% if (typeof weather !== 'undefined' && weather) { %>
                <div class="mt-4 info-card best-time-card reveal-on-scroll">
                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                        <div class="d-flex align-items-center gap-3">
                            <% if (weather.icon) { %>
                                <img src="<%= weather.icon %>" alt="<%= weather.conditionText || 'Weather icon' %>" width="48" height="48">
                            <% } %>
                            <div>
                                <h5 class="fw-bold mb-1">
                                    <i class="fas fa-cloud-sun me-2 text-primary"></i>
                                    Today’s weather & best time to visit
                                </h5>
                                <p class="small mb-1 text-muted">
                                    <% if (weather.conditionText) { %>
                                        <span><%= weather.conditionText %></span>
                                    <% } %>
                                    <% if (typeof weather.tempC === 'number') { %>
                                        · <span><%= weather.tempC.toFixed(1) %>°C</span>
                                    <% } %>
                                    <% if (typeof weather.feelsLikeC === 'number') { %>
                                        · <span>Feels like <%= weather.feelsLikeC.toFixed(1) %>°C</span>
                                    <% } %>
                                    <% if (weather.chanceOfRain) { %>
                                        · <span>Chance of rain: <%= weather.chanceOfRain %>%</span>
                                    <% } %>
                                </p>
                                <p class="mb-0">
                                    <strong><%= weather.bestTimeLabel %>:</strong>
                                    <span class="text-muted"><%= weather.bestTimeDetail %></span>
                                </p>
                            </div>
                        </div>
                    </div>

                    <% if (weather.forecastDays && weather.forecastDays.length > 0) { %>
                        <hr class="my-3 text-muted" style="opacity: 0.2;">
                        <div class="d-flex justify-content-around align-items-center flex-wrap mt-2">
                            <% weather.forecastDays.forEach(function(day, index) { %>
                                <div class="forecast-day-card text-center px-4 py-2">
                                    <p class="mb-1 fw-bold text-dark" style="font-size: 0.9rem;">
                                        <%= index === 0 ? 'Today' : day.date %>
                                    </p>
                                    <img src="<%= day.icon %>" alt="forecast icon" width="40" height="40" class="mb-1">
                                    <p class="mb-0" style="font-size: 0.85rem;">
                                        <span class="fw-bold text-danger" title="High"><%= day.maxTemp %>°</span>
                                        <span class="text-muted ms-1" title="Low"><%= day.minTemp %>°</span>
                                    </p>
                                </div>
                            <% }); %>
                        </div>
                    <% } %>
                </div>
            <% } %>

            <% const hasContact = (attraction.website && (Array.isArray(attraction.website) ? attraction.website.length : attraction.website)) || attraction.phone || attraction.email || attraction.facebook; %>
            <% if (hasContact) { %>
                <div class="mt-4 info-card contact-info-card reveal-on-scroll">
                    <h5 class="fw-bold mb-3"><i class="fas fa-address-card me-2 text-primary"></i>Contact & Info</h5>
                    <ul class="list-unstyled mb-0">
                        <% if (attraction.website) { 
                            const sites = Array.isArray(attraction.website) ? attraction.website : [attraction.website];
                            sites.forEach(function(url) { %>
                                <li class="mb-2">
                                    <a href="<%= url.startsWith('http') ? url : 'https://' + url %>" target="_blank" rel="noopener noreferrer" class="text-decoration-none">
                                        <i class="fas fa-globe me-2 text-success"></i><%= url.replace(/^https?:\/\//i, '') %>
                                    </a>
                                </li>
                        <% }); } %>
                        
                        <% if (attraction.facebook) { 
                            const fbLinks = Array.isArray(attraction.facebook) ? attraction.facebook : [attraction.facebook];
                            fbLinks.forEach(function(url) { %>
                                <li class="mb-2">
                                    <a href="<%= url.startsWith('http') ? url : 'https://' + url %>" target="_blank" rel="noopener noreferrer" class="text-decoration-none">
                                        <i class="fab fa-facebook me-2" style="color: #1877f2;"></i>Facebook Page
                                    </a>
                                </li>
                        <% }); } %>
                        
                        <% if (attraction.phone) { 
                            const phones = Array.isArray(attraction.phone) ? attraction.phone : [attraction.phone];
                            phones.forEach(function(p) { %>
                                <li class="mb-2">
                                    <a href="tel:<%= p.replace(/\s/g, '') %>" class="text-decoration-none">
                                        <i class="fas fa-phone me-2 text-primary"></i><%= p %>
                                    </a>
                                </li>
                        <% }); } %>
                        
                        <% if (attraction.email) { 
                            const emails = Array.isArray(attraction.email) ? attraction.email : [attraction.email];
                            emails.forEach(function(e) { %>
                                <li class="mb-2">
                                    <a href="mailto:<%= e %>" class="text-decoration-none">
                                        <i class="fas fa-envelope me-2 text-primary"></i><%= e %>
                                    </a>
                                </li>
                        <% }); } %>
                    </ul>
                </div>
            <% } %>

            <div class="mt-4 info-card reveal-on-scroll" id="reviews-section" data-attraction-id="<%= attraction.id %>">
                <h5 class="fw-bold mb-3"><i class="fas fa-comments me-2 text-primary"></i>Reviews</h5>
                <div id="reviews-list">
                    <% if (typeof reviews !== 'undefined' && reviews.length > 0) { %>
                        <% reviews.forEach(function(r) { %>
                        <div class="review-card review-item" data-review-id="<%= r.id %>">
                            <div class="d-flex gap-3 align-items-start">
                                <div class="review-avatar" aria-hidden="true">
                                    <%= (r.userName || r.userEmail || '?').charAt(0).toUpperCase() %>
                                </div>
                                <div class="flex-grow-1">
                            <div class="d-flex justify-content-between align-items-start flex-wrap gap-1">
                                <span class="fw-semibold"><%= r.userName || r.userEmail %></span>
                                <span class="small text-muted"><%= new Date(r.createdAt).toLocaleDateString() %></span>
                            </div>
                            <p class="mb-0 mt-1 text-secondary review-text"><%= r.text %></p>
                            <div class="d-flex justify-content-between align-items-center mt-2">
                                <div class="d-flex align-items-center gap-2">
                                    <% const reactionCount = (r.reactions && Object.keys(r.reactions).length) ? Object.keys(r.reactions).length : 0; %>
                                    <% const isOwner = (typeof user !== 'undefined' && user && r.userId && user.id && r.userId === user.id); %>
                                    <% const reacted = (typeof user !== 'undefined' && user && user.id && r.reactions && r.reactions[user.id]); %>
                                    <% if (typeof user !== 'undefined' && user && !isOwner) { %>
                                        <button type="button" class="btn btn-sm <%= reacted ? 'btn-primary' : 'btn-outline-primary' %> review-react-btn"
                                            data-review-id="<%= r.id %>">
                                            React <span class="badge text-bg-light ms-1 review-react-count"><%= reactionCount %></span>
                                        </button>
                                    <% } else { %>
                                        <span class="small text-muted"><%= (typeof user !== 'undefined' && user) ? 'You cannot react to your own review.' : 'Log in to react.' %></span>
                                        <span class="badge bg-light text-dark review-react-count"><%= reactionCount %></span>
                                    <% } %>
                                    <% if (typeof user !== 'undefined' && user) { %>
                                        <button type="button" class="btn btn-link btn-sm p-0 ms-2 review-reply-btn"
                                            data-review-id="<%= r.id %>">
                                            Reply
                                        </button>
                                    <% } %>
                                    <% if (typeof user !== 'undefined' && user && !isOwner) { %>
                                        <button type="button" class="btn btn-link btn-sm p-0 ms-2 review-report-btn"
                                            data-review-id="<%= r.id %>" title="Report this review">Report</button>
                                    <% } %>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <% if (typeof user !== 'undefined' && user && isOwner) { %>
                                        <button type="button" class="btn btn-sm btn-outline-secondary review-edit-btn" data-review-id="<%= r.id %>">Edit</button>
                                    <% } %>
                                    <% if (typeof user !== 'undefined' && user && (user.role === 'admin' || isOwner)) { %>
                                        <button type="button" class="btn btn-sm btn-outline-danger review-delete-btn" data-review-id="<%= r.id %>">Delete</button>
                                    <% } %>
                                </div>
                            </div>

                            <% if (r.replies && r.replies.length) { %>
                                <div class="mt-3 review-replies" data-review-id="<%= r.id %>">
                                    <% r.replies.forEach(function(rep) { %>
                                        <div class="review-reply mb-2" data-reply-id="<%= rep.id %>">
                                            <div class="d-flex justify-content-between align-items-start">
                                                <span class="fw-medium text-primary"><%= rep.userName || rep.userEmail %></span>
                                                <span class="small text-muted"><%= new Date(rep.createdAt).toLocaleDateString() %></span>
                                            </div>
                                            <p class="mb-1 mt-1 small text-secondary review-reply-text"><%= rep.text %></p>
                                            <div class="d-flex align-items-center gap-2 mb-1">
                                                <% 
                                                    const repReactionCount = (rep.reactions && Object.keys(rep.reactions).length) ? Object.keys(rep.reactions).length : 0;
                                                    const repIsOwner = (typeof user !== 'undefined' && user && rep.userId && user.id && rep.userId === user.id);
                                                    const repReacted = (typeof user !== 'undefined' && user && user.id && rep.reactions && rep.reactions[user.id]);
                                                %>
                                                <% if (typeof user !== 'undefined' && user && !repIsOwner) { %>
                                                    <button type="button" class="btn btn-sm <%= repReacted ? 'btn-primary' : 'btn-outline-primary' %> reply-react-btn"
                                                        data-review-id="<%= r.id %>"
                                                        data-reply-id="<%= rep.id %>">
                                                        React <span class="badge text-bg-light ms-1 reply-react-count"><%= repReactionCount %></span>
                                                    </button>
                                                <% } else { %>
                                                    <span class="small text-muted">
                                                        <%= (typeof user !== 'undefined' && user) ? 'You cannot react to your own reply.' : 'Log in to react.' %>
                                                    </span>
                                                    <span class="badge bg-light text-dark reply-react-count"><%= repReactionCount %></span>
                                                <% } %>
                                                <% if (typeof user !== 'undefined' && user) { %>
                                                    <button type="button" class="btn btn-link btn-sm p-0 ms-2 review-reply-btn"
                                                        data-review-id="<%= r.id %>"
                                                        data-parent-reply-id="<%= rep.id %>">
                                                        Reply
                                                    </button>
                                                <% } %>
                                                <% if (typeof user !== 'undefined' && user && repIsOwner) { %>
                                                    <button type="button" class="btn btn-link btn-sm p-0 ms-2 reply-edit-btn"
                                                        data-review-id="<%= r.id %>"
                                                        data-reply-id="<%= rep.id %>">Edit</button>
                                                <% } %>
                                                <% if (typeof user !== 'undefined' && user && !repIsOwner) { %>
                                                    <button type="button" class="btn btn-link btn-sm p-0 ms-2 reply-report-btn"
                                                        data-review-id="<%= r.id %>" data-reply-id="<%= rep.id %>" title="Report this reply">Report</button>
                                                <% } %>
                                            </div>
                                            <% if (rep.children && rep.children.length) { %>
                                                <div class="mt-2 review-replies-children">
                                                    <% rep.children.forEach(function(child) { %>
                                                        <div class="review-reply mb-2" data-reply-id="<%= child.id %>">
                                                            <div class="d-flex justify-content-between align-items-start">
                                                                <span class="fw-medium text-primary"><%= child.userName || child.userEmail %></span>
                                                                <span class="small text-muted"><%= new Date(child.createdAt).toLocaleDateString() %></span>
                                                            </div>
                                                            <p class="mb-1 mt-1 small text-secondary review-reply-text"><%= child.text %></p>
                                                            <div class="d-flex align-items-center gap-2 mb-1">
                                                                <% 
                                                                    const childReactionCount = (child.reactions && Object.keys(child.reactions).length) ? Object.keys(child.reactions).length : 0;
                                                                    const childIsOwner = (typeof user !== 'undefined' && user && child.userId && user.id && child.userId === user.id);
                                                                    const childReacted = (typeof user !== 'undefined' && user && user.id && child.reactions && child.reactions[user.id]);
                                                                %>
                                                                <% if (typeof user !== 'undefined' && user && !childIsOwner) { %>
                                                                    <button type="button" class="btn btn-sm <%= childReacted ? 'btn-primary' : 'btn-outline-primary' %> reply-react-btn"
                                                                        data-review-id="<%= r.id %>"
                                                                        data-reply-id="<%= child.id %>">
                                                                        React <span class="badge text-bg-light ms-1 reply-react-count"><%= childReactionCount %></span>
                                                                    </button>
                                                                <% } else { %>
                                                                    <span class="small text-muted">
                                                                        <%= (typeof user !== 'undefined' && user) ? 'You cannot react to your own reply.' : 'Log in to react.' %>
                                                                    </span>
                                                                    <span class="badge bg-light text-dark reply-react-count"><%= childReactionCount %></span>
                                                                <% } %>
                                                                <% if (typeof user !== 'undefined' && user) { %>
                                                                    <button type="button" class="btn btn-link btn-sm p-0 ms-2 review-reply-btn"
                                                                        data-review-id="<%= r.id %>"
                                                                        data-parent-reply-id="<%= child.id %>">
                                                                        Reply
                                                                    </button>
                                                                <% } %>
                                                                <% if (typeof user !== 'undefined' && user && childIsOwner) { %>
                                                                    <button type="button" class="btn btn-link btn-sm p-0 ms-2 reply-edit-btn"
                                                                        data-review-id="<%= r.id %>"
                                                                        data-reply-id="<%= child.id %>">Edit</button>
                                                                <% } %>
                                                                <% if (typeof user !== 'undefined' && user && !childIsOwner) { %>
                                                                    <button type="button" class="btn btn-link btn-sm p-0 ms-2 reply-report-btn"
                                                                        data-review-id="<%= r.id %>" data-reply-id="<%= child.id %>" title="Report this reply">Report</button>
                                                                <% } %>
                                                            </div>
                                                        </div>
                                                    <% }); %>
                                                </div>
                                            <% } %>
                                        </div>
                                    <% }); %>
                                </div>
                            <% } else { %>
                                <div class="mt-3 review-replies" data-review-id="<%= r.id %>"></div>
                            <% } %>
                                </div><!-- /flex-grow-1 -->
                            </div><!-- /d-flex gap-3 -->
                        </div>
                        <% }); %>
                    <% } else { %>
                        <p class="text-muted mb-0" id="reviews-empty">No reviews yet. Be the first to share your experience!</p>
                    <% } %>
                </div>
                <div class="mt-3 pt-3 border-top">
                    <% if (typeof user !== 'undefined' && user) { %>
                    <form id="review-form">
                        <label for="review-text" class="form-label">Leave a review</label>
                        <textarea class="form-control mb-2" id="review-text" name="text" rows="3" placeholder="Share your experience..." maxlength="1000" required></textarea>
                        <button type="submit" class="btn btn-primary btn-sm rounded-pill px-3" id="review-submit">Post review</button>
                    </form>
                    <% } else { %>
                    <p class="text-muted mb-0">
                        <a href="/login?redirect=<%= encodeURIComponent('/attraction/' + attraction.id) %>" class="text-primary">Log in</a> to leave a review.
                    </p>
                    <% } %>
                </div>
            </div>
        </div>

        <div class="col-lg-5 reveal-on-scroll">
            <div class="card shadow-sm border-0 sticky-top" style="top: 20px;">
                <div class="card-body p-0">
                    <div id="map" data-mapbox-token="<%= typeof mapboxToken !== 'undefined' ? mapboxToken : '' %>"></div>
                </div>
                <div class="card-footer bg-transparent p-3 d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="fw-bold mb-1">How to get there</h5>
                        <% if (attraction.coordinates && attraction.coordinates.length === 2) { %>
                            <p class="small text-muted mb-0">Location: Naujan, Oriental Mindoro</p>
                        <% } else { %>
                            <p class="small text-muted mb-0">This place location is soon to be showed.</p>
                        <% } %>
                    </div>
                    <% if (attraction.coordinates && attraction.coordinates.length === 2) { %>
                        <a href="https://www.google.com/maps/dir/?api=1&destination=<%= attraction.coordinates[1] %>,<%= attraction.coordinates[0] %>"
                            target="_blank" class="btn btn-primary btn-sm rounded-pill px-3 shadow-sm">
                            <i class="fas fa-directions me-1"></i> Get Directions
                        </a>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<% 
const hasRoomsOrMenu = (attraction.rooms && attraction.rooms.length) || (attraction.menu && attraction.menu.length) || (attraction.addons && attraction.addons.length);
const hasRent = attraction.rent && attraction.rent.length;
const showPackagesModal = hasRoomsOrMenu || hasRent;
%>

<% if (showPackagesModal) { %>
    <div class="modal fade" id="accommodationInfoModal" tabindex="-1" aria-labelledby="accommodationInfoModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="accommodationInfoModalLabel">
                        <%= attraction.name %> – Details
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <% if (hasRent) { %>
                        <h6 class="fw-bold mb-2">Rental Packages</h6>
                        <div class="row g-3 mb-3">
                            <% attraction.rent.forEach(function(r) { %>
                                <div class="col-12 col-md-6 col-lg-4">
                                    <div class="card h-100 shadow-sm border-0">
                                        <% if (r.image) { %>
                                            <img src="<%= typeof imageBaseUrl !== 'undefined' ? imageBaseUrl : '' %><%= r.image %>" class="card-img-top" alt="<%= r.name %>" loading="lazy" decoding="async" style="height: 140px; object-fit: cover;">
                                        <% } %>
                                        <div class="card-body">
                                            <h6 class="card-title mb-1"><%= r.name %></h6>
                                            <% if (r.details) { %>
                                                <p class="card-text small mb-2"><%= r.details %></p>
                                            <% } %>
                                            <% if (r.price) { %>
                                                <span class="badge bg-success-subtle text-success-emphasis small px-2 py-1">
                                                    <%- r.price.replace(/\n/g, '<br>') %>
                                                </span>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    <% } %>

                    <% if (hasRoomsOrMenu) { %>
                        <% if (attraction.rooms && attraction.rooms.length) { %>
                            <h6 class="fw-bold mb-2">Room Options</h6>
                            <div class="row g-3 mb-3">
                                <% attraction.rooms.forEach(function(room) { %>
                                    <div class="col-12 col-md-6 col-lg-4">
                                        <div class="card h-100 shadow-sm border-0">
                                            <% if (room.image) { %>
                                                <img src="<%= typeof imageBaseUrl !== 'undefined' ? imageBaseUrl : '' %><%= room.image %>" class="card-img-top" alt="<%= room.name %>" loading="lazy" decoding="async" style="height: 140px; object-fit: cover;">
                                            <% } %>
                                            <div class="card-body">
                                                <h6 class="card-title mb-1"><%= room.name %></h6>
                                                <p class="card-text small mb-2"><%= room.details %></p>
                                                <% if (room.price) { %>
                                                    <span class="badge bg-success-subtle text-success-emphasis small px-2 py-1">
                                                        <%- room.price.replace(/\n/g, '<br>') %>
                                                    </span>
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                <% }); %>
                            </div>
                        <% } %>

                        <% if (attraction.menu && attraction.menu.length) { %>
                            <h6 class="fw-bold mb-2 mt-3">Menu Highlights</h6>
                            <div class="row g-3 mb-3">
                                <% attraction.menu.forEach(function(item) { %>
                                    <div class="col-12 col-md-6 col-lg-4">
                                        <div class="card h-100 shadow-sm border-0">
                                            <% if (item.image) { %>
                                                <img src="<%= typeof imageBaseUrl !== 'undefined' ? imageBaseUrl : '' %><%= item.image %>" class="card-img-top" alt="<%= item.name %>" loading="lazy" decoding="async" style="height: 140px; object-fit: cover;">
                                            <% } %>
                                            <div class="card-body">
                                                <h6 class="card-title mb-1"><%= item.name %></h6>
                                                <p class="card-text small mb-2"><%= item.details %></p>
                                                <% if (item.price) { %>
                                                    <span class="badge bg-primary-subtle text-primary-emphasis small px-2 py-1">
                                                        <%- item.price.replace(/\n/g, '<br>') %>
                                                    </span>
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                <% }); %>
                            </div>
                        <% } %>

                        <% if (attraction.addons && attraction.addons.length) { %>
                            <h6 class="fw-bold mb-2 mt-3">Add-ons & Other Fees</h6>
                            <div class="row g-3">
                                <% attraction.addons.forEach(function(item) { %>
                                    <div class="col-12 col-md-6 col-lg-4">
                                        <div class="card h-100 shadow-sm border-0">
                                            <% if (item.image) { %>
                                                <img src="<%= typeof imageBaseUrl !== 'undefined' ? imageBaseUrl : '' %><%= item.image %>" class="card-img-top" alt="<%= item.name %>" loading="lazy" decoding="async" style="height: 140px; object-fit: cover;">
                                            <% } %>
                                            <div class="card-body">
                                                <h6 class="card-title mb-1"><%= item.name %></h6>
                                                <% if (item.details) { %>
                                                    <p class="card-text small mb-2"><%= item.details %></p>
                                                <% } %>
                                                <% if (item.price) { %>
                                                    <span class="badge bg-info-subtle text-info-emphasis small px-2 py-1">
                                                        <%- item.price.replace(/\n/g, '<br>') %>
                                                    </span>
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                <% }); %>
                            </div>
                        <% } %>
                    <% } %>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>
<% } %>

<script src="https://api.mapbox.com/mapbox-gl-js/v2.14.1/mapbox-gl.js"></script>
<script>
    var mapboxToken = document.getElementById('map').getAttribute('data-mapbox-token') || '';
    mapboxgl.accessToken = mapboxToken;
    if (mapboxToken) {
        <% if (attraction.coordinates && attraction.coordinates.length === 2) { %>
        var map = new mapboxgl.Map({
            container: 'map',
            style: 'mapbox://styles/mapbox/outdoors-v12',
            center: [<%= attraction.coordinates[0] %>, <%= attraction.coordinates[1] %>],
            zoom: 13
        });
        map.addControl(new mapboxgl.NavigationControl());
        new mapboxgl.Marker({ color: "#FF0000" })
            .setLngLat([<%= attraction.coordinates[0] %>, <%= attraction.coordinates[1] %>])
            .setPopup(new mapboxgl.Popup().setHTML("<h5><%= attraction.name %></h5>"))
            .addTo(map);
        <% } else { %>
        document.getElementById('map').innerHTML = '<div class="d-flex align-items-center justify-content-center h-100 bg-light rounded"><p class="text-muted mb-0">This place location is soon to be showed.</p></div>';
        <% } %>
    } else {
        document.getElementById('map').innerHTML = '<div class="d-flex align-items-center justify-content-center h-100 bg-light rounded"><p class="text-muted mb-0">Set MAPBOX_ACCESS_TOKEN in your environment to show the map.</p></div>';
    }
</script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/fslightbox/3.3.1/index.js"></script>
<script>
(function() {
    var section = document.getElementById('reviews-section');
    var attractionId = section && section.getAttribute('data-attraction-id');
    var reviewsList = document.getElementById('reviews-list');
    var emptyEl = document.getElementById('reviews-empty');
    var form = document.getElementById('review-form');
    var textarea = document.getElementById('review-text');
    var submitBtn = document.getElementById('review-submit');

    function esc(s) {
        return String(s || '').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    function redirectToLogin() {
        window.location.href = '/login?redirect=' + encodeURIComponent(window.location.pathname);
    }

    if (form) {
        form.addEventListener('submit', function(e) {
            e.preventDefault();
            var text = textarea && textarea.value.trim();
            if (!text || !attractionId) return;
            if (submitBtn) submitBtn.disabled = true;
            fetch('/api/reviews/' + encodeURIComponent(attractionId), {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ text: text })
            }).then(function(r) {
                if (r.status === 401) return redirectToLogin();
                return r.json();
            }).then(function(data) {
                if (submitBtn) submitBtn.disabled = false;
                if (!data || data.error) return;
                if (emptyEl) emptyEl.remove();
                var div = document.createElement('div');
                div.className = 'border-bottom pb-3 mb-3 review-item';
                div.setAttribute('data-review-id', data.id);
                var dateStr = data.createdAt ? new Date(data.createdAt).toLocaleDateString() : '';
                var displayName = esc(data.userName || data.userEmail || '');
                var textHtml = esc(data.text || '');
                div.innerHTML =
                    '<div class="d-flex justify-content-between align-items-start">' +
                        '<span class="fw-medium text-primary">' + displayName + '</span>' +
                        '<span class="small text-muted">' + dateStr + '</span>' +
                    '</div>' +
                    '<p class="mb-0 mt-1 text-secondary review-text">' + textHtml + '</p>' +
                    '<div class="d-flex justify-content-between align-items-center mt-2">' +
                        '<div class="d-flex align-items-center gap-2">' +
                            '<span class="small text-muted">You cannot react to your own review.</span>' +
                            '<span class="badge bg-light text-dark review-react-count">0</span>' +
                            (form ? '<button type="button" class="btn btn-link btn-sm p-0 ms-2 review-reply-btn" data-review-id="' + esc(data.id) + '">Reply</button>' : '') +
                        '</div>' +
                        '<div class="d-flex align-items-center gap-2">' +
                            '<button type="button" class="btn btn-sm btn-outline-secondary review-edit-btn" data-review-id="' + esc(data.id) + '">Edit</button>' +
                            '<button type="button" class="btn btn-sm btn-outline-danger review-delete-btn" data-review-id="' + esc(data.id) + '">Delete</button>' +
                        '</div>' +
                    '</div>' +
                    '<div class="mt-3 review-replies" data-review-id="' + esc(data.id) + '"></div>';
                if (reviewsList) reviewsList.insertBefore(div, reviewsList.firstChild);
                if (textarea) textarea.value = '';
            }).catch(function() {
                if (submitBtn) submitBtn.disabled = false;
            });
        });
    }

    if (section) {
        section.addEventListener('click', function(e) {
            var delBtn = e.target.closest && e.target.closest('.review-delete-btn');
            if (delBtn && attractionId) {
                var reviewId = delBtn.getAttribute('data-review-id');
                if (!reviewId) return;
                appConfirm('Delete this review?', function() {
                    fetch('/api/reviews/' + encodeURIComponent(attractionId) + '/' + encodeURIComponent(reviewId), {
                        method: 'DELETE'
                    }).then(function(r) {
                        if (r.status === 401) return redirectToLogin();
                        return r.json();
                    }).then(function(data) {
                        if (data && data.ok) {
                            var item = delBtn.closest('.review-item');
                            if (item) item.remove();
                        }
                    }).catch(function() {});
                });
                return;
            }

            var reviewEditBtn = e.target.closest && e.target.closest('.review-edit-btn');
            if (reviewEditBtn && attractionId) {
                var reviewId = reviewEditBtn.getAttribute('data-review-id');
                if (!reviewId) return;
                var reviewItem = reviewEditBtn.closest('.review-item');
                if (!reviewItem) return;
                var textEl = reviewItem.querySelector('.review-text');
                if (!textEl || reviewItem.querySelector('.review-edit-form')) return;
                var originalText = textEl.textContent || '';
                var formDiv = document.createElement('div');
                formDiv.className = 'review-edit-form mt-1';
                var textarea = document.createElement('textarea');
                textarea.className = 'form-control form-control-sm mb-2';
                textarea.rows = 3;
                textarea.value = originalText;
                textarea.maxLength = 1000;
                var btnWrap = document.createElement('div');
                btnWrap.className = 'd-flex gap-2';
                var saveBtn = document.createElement('button');
                saveBtn.type = 'button';
                saveBtn.className = 'btn btn-sm btn-primary review-edit-save-btn';
                saveBtn.textContent = 'Save';
                var cancelBtn = document.createElement('button');
                cancelBtn.type = 'button';
                cancelBtn.className = 'btn btn-sm btn-outline-secondary review-edit-cancel-btn';
                cancelBtn.textContent = 'Cancel';
                btnWrap.appendChild(saveBtn);
                btnWrap.appendChild(cancelBtn);
                formDiv.appendChild(textarea);
                formDiv.appendChild(btnWrap);
                textEl.replaceWith(formDiv);

                function restoreReview() {
                    var p = document.createElement('p');
                    p.className = 'mb-0 mt-1 text-secondary review-text';
                    p.textContent = originalText;
                    formDiv.replaceWith(p);
                }

                cancelBtn.addEventListener('click', restoreReview);

                saveBtn.addEventListener('click', function() {
                    var newText = textarea.value.trim();
                    if (!newText) return;
                    saveBtn.disabled = true;
                    fetch('/api/reviews/' + encodeURIComponent(attractionId) + '/' + encodeURIComponent(reviewId), {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ text: newText })
                    }).then(function(r) {
                        if (r.status === 401) return redirectToLogin();
                        return r.json();
                    }).then(function(data) {
                        saveBtn.disabled = false;
                        if (!data || data.error) return;
                        originalText = data.text || newText;
                        var p = document.createElement('p');
                        p.className = 'mb-0 mt-1 text-secondary review-text';
                        p.textContent = originalText;
                        formDiv.replaceWith(p);
                    }).catch(function() { saveBtn.disabled = false; });
                });
                return;
            }

            var replyEditBtn = e.target.closest && e.target.closest('.reply-edit-btn');
            if (replyEditBtn && attractionId) {
                var reviewIdReply = replyEditBtn.getAttribute('data-review-id');
                var replyId = replyEditBtn.getAttribute('data-reply-id');
                if (!reviewIdReply || !replyId) return;
                var replyBlock = replyEditBtn.closest('.review-reply');
                if (!replyBlock) return;
                var replyTextEl = replyBlock.querySelector('.review-reply-text');
                if (!replyTextEl || replyBlock.querySelector('.review-edit-form')) return;
                var originalReplyText = replyTextEl.textContent || '';
                var formDivReply = document.createElement('div');
                formDivReply.className = 'review-edit-form mt-1';
                var textareaReply = document.createElement('textarea');
                textareaReply.className = 'form-control form-control-sm mb-2';
                textareaReply.rows = 2;
                textareaReply.value = originalReplyText;
                textareaReply.maxLength = 1000;
                var btnWrapReply = document.createElement('div');
                btnWrapReply.className = 'd-flex gap-2';
                var saveBtnReply = document.createElement('button');
                saveBtnReply.type = 'button';
                saveBtnReply.className = 'btn btn-sm btn-primary review-edit-save-btn';
                saveBtnReply.textContent = 'Save';
                var cancelBtnReply = document.createElement('button');
                cancelBtnReply.type = 'button';
                cancelBtnReply.className = 'btn btn-sm btn-outline-secondary review-edit-cancel-btn';
                cancelBtnReply.textContent = 'Cancel';
                btnWrapReply.appendChild(saveBtnReply);
                btnWrapReply.appendChild(cancelBtnReply);
                formDivReply.appendChild(textareaReply);
                formDivReply.appendChild(btnWrapReply);
                replyTextEl.replaceWith(formDivReply);

                function restoreReply() {
                    var p = document.createElement('p');
                    p.className = 'mb-1 mt-1 small text-secondary review-reply-text';
                    p.textContent = originalReplyText;
                    formDivReply.replaceWith(p);
                }

                cancelBtnReply.addEventListener('click', restoreReply);

                saveBtnReply.addEventListener('click', function() {
                    var newTextReply = textareaReply.value.trim();
                    if (!newTextReply) return;
                    saveBtnReply.disabled = true;
                    fetch('/api/reviews/' + encodeURIComponent(attractionId) + '/' + encodeURIComponent(reviewIdReply) + '/replies/' + encodeURIComponent(replyId), {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ text: newTextReply })
                    }).then(function(r) {
                        if (r.status === 401) return redirectToLogin();
                        return r.json();
                    }).then(function(data) {
                        saveBtnReply.disabled = false;
                        if (!data || data.error) return;
                        originalReplyText = data.text || newTextReply;
                        var p = document.createElement('p');
                        p.className = 'mb-1 mt-1 small text-secondary review-reply-text';
                        p.textContent = originalReplyText;
                        formDivReply.replaceWith(p);
                    }).catch(function() { saveBtnReply.disabled = false; });
                });
                return;
            }

            var reviewReportBtn = e.target.closest && e.target.closest('.review-report-btn');
            if (reviewReportBtn && attractionId) {
                var reviewId = reviewReportBtn.getAttribute('data-review-id');
                if (!reviewId) return;
                appConfirm('Report this review? The admin will review it.', function() {
                    fetch('/api/reports', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ attractionId: attractionId, reviewId: reviewId })
                }).then(function(r) {
                    if (r.status === 401) return redirectToLogin();
                    return r.json();
                }).then(function(data) {
                        if (data && data.error) { appAlert(data.error); return; }
                        appAlert('Report submitted. Thank you.');
                    }).catch(function() {});
                });
                return;
            }

            var replyReportBtn = e.target.closest && e.target.closest('.reply-report-btn');
            if (replyReportBtn && attractionId) {
                var reviewIdRep = replyReportBtn.getAttribute('data-review-id');
                var replyIdRep = replyReportBtn.getAttribute('data-reply-id');
                if (!reviewIdRep) return;
                appConfirm('Report this reply? The admin will review it.', function() {
                    fetch('/api/reports', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ attractionId: attractionId, reviewId: reviewIdRep, replyId: replyIdRep || null })
                }).then(function(r) {
                    if (r.status === 401) return redirectToLogin();
                    return r.json();
                }).then(function(data) {
                    if (data && data.error) { appAlert(data.error); return; }
                    appAlert('Report submitted. Thank you.');
                }).catch(function() {});
                });
                return;
            }

            var reactBtn = e.target.closest && e.target.closest('.review-react-btn');
            if (reactBtn && attractionId) {
                var rid = reactBtn.getAttribute('data-review-id');
                if (!rid) return;
                fetch('/api/reviews/' + encodeURIComponent(attractionId) + '/' + encodeURIComponent(rid) + '/react', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ action: 'toggle' })
                }).then(function(r) {
                    if (r.status === 401) return redirectToLogin();
                    return r.json();
                }).then(function(data) {
                    if (!data || data.error) return;
                    var countEl = reactBtn.querySelector('.review-react-count');
                    if (countEl) countEl.textContent = String(data.count || 0);
                    reactBtn.classList.toggle('btn-primary', !!data.reacted);
                    reactBtn.classList.toggle('btn-outline-primary', !data.reacted);
                }).catch(function() {});
            }

            var replyReactBtn = e.target.closest && e.target.closest('.reply-react-btn');
            if (replyReactBtn && attractionId) {
                var reviewIdForReply = replyReactBtn.getAttribute('data-review-id');
                var replyId = replyReactBtn.getAttribute('data-reply-id');
                if (!reviewIdForReply || !replyId) return;
                fetch('/api/reviews/' + encodeURIComponent(attractionId) + '/' + encodeURIComponent(reviewIdForReply) + '/replies/' + encodeURIComponent(replyId) + '/react', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ action: 'toggle' })
                }).then(function(r) {
                    if (r.status === 401) return redirectToLogin();
                    return r.json();
                }).then(function(data) {
                    if (!data || data.error) return;
                    var countEl = replyReactBtn.querySelector('.reply-react-count');
                    if (countEl) countEl.textContent = String(data.count || 0);
                    replyReactBtn.classList.toggle('btn-primary', !!data.reacted);
                    replyReactBtn.classList.toggle('btn-outline-primary', !data.reacted);
                }).catch(function() {});
            }

            var replyBtn = e.target.closest && e.target.closest('.review-reply-btn');
            if (replyBtn && attractionId) {
                var reviewId = replyBtn.getAttribute('data-review-id');
                if (!reviewId) return;
                var parentReplyId = replyBtn.getAttribute('data-parent-reply-id') || '';
                appPrompt('Reply to this comment:', '', function(replyText) {
                    if (!replyText) return;
                    replyText = replyText.trim();
                    if (!replyText) return;

                    fetch('/api/reviews/' + encodeURIComponent(attractionId) + '/' + encodeURIComponent(reviewId) + '/replies', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ text: replyText, parentReplyId: parentReplyId || null })
                }).then(function(r) {
                    if (r.status === 401) return redirectToLogin();
                    return r.json();
                }).then(function(data) {
                    if (!data || data.error) return;
                    var reviewItem = section.querySelector('.review-item[data-review-id="' + esc(data.reviewId) + '"]') ||
                                     section.querySelector('.review-item[data-review-id="' + reviewId + '"]');
                    if (!reviewItem) return;

                    var repliesRoot = reviewItem.querySelector('.review-replies[data-review-id="' + (data.reviewId || reviewId) + '"]');
                    if (!repliesRoot) {
                        repliesRoot = document.createElement('div');
                        repliesRoot.className = 'mt-3 review-replies';
                        repliesRoot.setAttribute('data-review-id', data.reviewId || reviewId);
                        reviewItem.appendChild(repliesRoot);
                    }

                    var dateStr = data.createdAt ? new Date(data.createdAt).toLocaleDateString() : '';
                    var displayName = esc(data.userName || data.userEmail || '');
                    var textHtml = esc(data.text || '');

                    var html =
                        '<div class="border-start ps-3 mb-2 review-reply" data-reply-id="' + esc(data.id) + '">' +
                            '<div class="d-flex justify-content-between align-items-start">' +
                                '<span class="fw-medium text-primary">' + displayName + '</span>' +
                                '<span class="small text-muted">' + dateStr + '</span>' +
                            '</div>' +
                            '<p class="mb-1 mt-1 small text-secondary review-reply-text">' + textHtml + '</p>' +
                            '<div class="d-flex align-items-center gap-2 mb-1">' +
                                '<span class="small text-muted">You cannot react to your own reply.</span>' +
                                '<span class="badge bg-light text-dark reply-react-count">0</span>' +
                                '<button type="button" class="btn btn-link btn-sm p-0 ms-2 review-reply-btn" data-review-id="' + esc(data.reviewId || reviewId) + '" data-parent-reply-id="' + esc(data.id) + '">Reply</button>' +
                                '<button type="button" class="btn btn-link btn-sm p-0 ms-2 reply-edit-btn" data-review-id="' + esc(data.reviewId || reviewId) + '" data-reply-id="' + esc(data.id) + '">Edit</button>' +
                            '</div>' +
                        '</div>';

                    if (data.parentReplyId) {
                        var parentReply = reviewItem.querySelector('.review-reply[data-reply-id="' + esc(data.parentReplyId) + '"]') ||
                                          reviewItem.querySelector('.review-reply[data-reply-id="' + data.parentReplyId + '"]');
                        if (parentReply) {
                            var childrenContainer = parentReply.querySelector('.review-replies-children');
                            if (!childrenContainer) {
                                childrenContainer = document.createElement('div');
                                childrenContainer.className = 'mt-2 review-replies-children';
                                parentReply.appendChild(childrenContainer);
                            }
                            var wrapperChild = document.createElement('div');
                            wrapperChild.innerHTML = html;
                            childrenContainer.appendChild(wrapperChild.firstChild);
                            return;
                        }
                    }

                    var wrapper = document.createElement('div');
                    wrapper.innerHTML = html;
                    repliesRoot.appendChild(wrapper.firstChild);
                }).catch(function() {});
                });
            }
        });
    }
})();
</script>

<style>
    /* Styling for the 3-day forecast cards */
    .forecast-day-card {
        transition: all 0.2s ease-in-out;
        border-radius: 12px;
        border: 1px solid transparent;
        cursor: default;
    }

    .forecast-day-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 6px 15px rgba(0, 0, 0, 0.08);
        border-color: #e9ecef;
        background-color: #f8f9fa;
    }
</style>

<% loaderMessage = attraction.name + ' loading'; %>
<%- include('partials/footer') %>