<%- include('partials/header') %>

<main class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4 p-md-5">
                    <h1 class="h3 fw-bold text-center mb-4">Reset your password</h1>
                    <p class="text-muted small mb-4 text-center">
                        Choose a new password for your account.
                    </p>
                    <form action="/reset-password" method="post">
                        <input type="hidden" name="email" value="<%= email %>">
                        <input type="hidden" name="token" value="<%= token %>">
                        <div class="mb-3">
                            <label for="new-password" class="form-label">New password (min 6 characters)</label>
                            <input type="password" class="form-control" id="new-password" name="password" required minlength="6" autocomplete="new-password">
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Update password</button>
                    </form>
                    <p class="text-muted small text-center mt-4 mb-0">
                        <a href="/login" class="text-decoration-none">← Back to login</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include('partials/footer') %>

