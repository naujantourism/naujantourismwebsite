<%- include('partials/header') %>

<section class="auth-wrapper container">
    <div class="row justify-content-center w-100">
        <div class="col-md-10 col-lg-7 col-xl-5">
            <div class="auth-card">
                <div class="text-center mb-4">
                    <span class="badge rounded-pill px-3 py-2 mb-3" style="background: var(--accent-bg); color: var(--accent); font-weight: 600;">
                        <i class="fas fa-lock me-1"></i> New Password
                    </span>
                    <h1 class="h3 fw-bold">Reset your password</h1>
                </div>
                    <p class="small mb-4 text-center" style="color: var(--text-secondary);">
                        Choose a new password for your account.
                    </p>
                    <form action="/reset-password" method="post">
                        <input type="hidden" name="email" value="<%= email %>">
                        <input type="hidden" name="token" value="<%= token %>">
                        <div class="mb-3">
                            <label for="new-password" class="form-label">New password (min 6 characters)</label>
                            <div class="input-group">
                                <input type="password" class="form-control" id="new-password" name="password" required minlength="6" autocomplete="new-password">
                                <button type="button" class="btn btn-pw-toggle" aria-label="Show password" tabindex="-1">
                                    <i class="fas fa-eye" aria-hidden="true"></i>
                                </button>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 rounded-pill">Update password</button>
                    </form>
                    <p class="small text-center mt-4 mb-0" style="color: var(--text-secondary);">
                        <a href="/login" class="text-decoration-none" style="color: var(--accent);"><i class="fas fa-arrow-left me-1"></i> Back to login</a>
                    </p>
            </div>
        </div>
    </div>
</section>

<%- include('partials/footer') %>

